# --- Single account (optional if using multi-account below) ---
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# FROM_EMAIL=businessmoana118@gmail.com

# --- Two (or more) Gmail accounts: round-robin (1st → account 1, 2nd → account 2, 3rd → account 1, ...) ---
# Create App Passwords at: https://myaccount.google.com/apppasswords
# ACCOUNT_1_EMAIL=first@gmail.com
# ACCOUNT_1_APP_PASSWORD=xxxx xxxx xxxx xxxx
# ACCOUNT_2_EMAIL=second@gmail.com
# ACCOUNT_2_APP_PASSWORD=xxxx xxxx xxxx xxxx
# (ACCOUNT_3_EMAIL, ACCOUNT_3_APP_PASSWORD, ... up to 10)

# Max emails per account this run (e.g. 200 to stay under Gmail daily limits)
# PER_ACCOUNT_LIMIT=200

# Delay between each send (ms). Higher = fewer "too many login attempts" (454)
# DELAY_MS=10000

# Optional: customize subject and body
# SUBJECT=Hello
# BODY=Your message text here.

# Optional: limit number of recipients (e.g. for testing)
# LIMIT=5

# Rate-limit recovery (optional)
# RATE_LIMIT_WAIT_MINUTES=30
# DAILY_LIMIT_WAIT_HOURS=24

# If you get ETIMEDOUT to 10.x.x.x: SMTP_BYPASS_DNS=1 (default). To force 587: SMTP_SSL=0
