# Gmail App Password (required)
# Create at: https://myaccount.google.com/apppasswords
# Use your account businessmoana118@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Optional: customize subject and body
# SUBJECT=Hello
# BODY=Your message text here.

# Optional: limit number of recipients (e.g. for testing)
# LIMIT=5

# If you get ETIMEDOUT to 10.x.x.x, the script resolves smtp.gmail.com via Google DNS (8.8.8.8)
# and connects to that IP (TLS SNI still uses smtp.gmail.com). To disable: SMTP_BYPASS_DNS=0
# To force port 587 instead of 465: SMTP_SSL=0
